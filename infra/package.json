{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy:fuji": "cdk deploy -c username=fuji -c vpccidr=10.0.0.0/16",
    "deploy:user1": "cdk deploy -c username=user1 -c vpccidr=10.1.0.0/16",
    "deploy:user2": "cdk deploy -c username=user2 -c vpccidr=10.2.0.0/16",
    "destroy:fuji": "cdk destroy -c username=fuji -c vpccidr=10.0.0.0/16",
    "destroy:user1": "cdk destroy -c username=user1 -c vpccidr=10.1.0.0/16",
    "destroy:user2": "cdk destroy -c username=user2 -c vpccidr=10.2.0.0/16"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "aws-cdk": "2.1021.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.205.0",
    "constructs": "^10.0.0"
  }
}
